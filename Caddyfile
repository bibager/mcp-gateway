:8080 {
    # Health check for the gateway itself
    handle /health {
        respond "OK" 200
    }

    # --- Todoist MCP: todoist.bibager.com (MUST be before GA OAuth routes) ---
    @todoist header Host todoist.bibager.com
    handle @todoist {
        reverse_proxy localhost:8001
    }

    # --- Monarch MCP: monarch.bibager.com ---
    @monarch header Host monarch.bibager.com
    handle @monarch {
        reverse_proxy localhost:8000
    }

    # --- GitLab MCP: gitlab.bibager.com (future) ---
    @gitlab header Host gitlab.bibager.com
    handle @gitlab {
        reverse_proxy localhost:8003
    }

    # --- Weather MCP: weather.bibager.com ---
    @weather header Host weather.bibager.com
    handle @weather {
        reverse_proxy localhost:8004
    }

    # --- TrackIQ MCP: trackiq.bibager.com ---
    @trackiq header Host trackiq.bibager.com
    handle @trackiq {
        reverse_proxy localhost:8005
    }

    # --- Framer MCP: framer.bibager.com (Python frontend on 8007 -> Node sidecar on 8006) ---
    @framer header Host framer.bibager.com
    handle @framer {
        reverse_proxy localhost:8007
    }

    # --- Pacvue MCP: pacvue.bibager.com ---
    @pacvue header Host pacvue.bibager.com
    handle @pacvue {
        reverse_proxy localhost:8008
    }

    # --- Alpaca MCP: alpaca.bibager.com (proxy on 8009 -> upstream alpaca-mcp-server on 8010, localhost-only) ---
    @alpaca header Host alpaca.bibager.com
    handle @alpaca {
        reverse_proxy localhost:8009
    }

    # --- TA (Technical Analysis) MCP: ta.bibager.com (computes pivots/VWAP/volume profile from Alpaca data) ---
    @ta header Host ta.bibager.com
    handle @ta {
        reverse_proxy localhost:8011
    }

    # --- Unusual Whales MCP: uw.bibager.com (proxy to api.unusualwhales.com/api/mcp) ---
    @uw header Host uw.bibager.com
    handle @uw {
        reverse_proxy localhost:8012
    }

    # --- Datarova MCP: datarova.bibager.com (Amazon brand rank tracker) ---
    @datarova header Host datarova.bibager.com
    handle @datarova {
        reverse_proxy localhost:8013
    }

    # --- Keepa MCP: keepa.bibager.com (Amazon historical price/BSR/buybox via Keepa API) ---
    @keepa header Host keepa.bibager.com
    handle @keepa {
        reverse_proxy localhost:8014
    }

    # --- ScrapingBee MCP: scrapingbee.bibager.com (live Amazon competitor content + reviews) ---
    @scrapingbee header Host scrapingbee.bibager.com
    handle @scrapingbee {
        reverse_proxy localhost:8015
    }

    # --- Oxylabs MCP: oxylabs.bibager.com (Amazon Web Scraper API — A/B against ScrapingBee) ---
    @oxylabs header Host oxylabs.bibager.com
    handle @oxylabs {
        reverse_proxy localhost:8016
    }

    # --- GA MCP: mcp.bibager.com/ga/* and root OAuth ---
    @ga_path path /ga/*
    handle @ga_path {
        uri strip_prefix /ga
        reverse_proxy localhost:8002
    }

    # GA OAuth endpoints at root (for Claude OAuth discovery on mcp.bibager.com only)
    @ga_oauth path /.well-known/oauth-protected-resource /.well-known/oauth-authorization-server /register /authorize /callback /token
    handle @ga_oauth {
        reverse_proxy localhost:8002
    }

    # Fallback path-based routes (for direct access)
    handle_path /monarch/* {
        reverse_proxy localhost:8000
    }

    handle_path /todoist/* {
        reverse_proxy localhost:8001
    }

    handle_path /gitlab/* {
        reverse_proxy localhost:8003
    }

    handle_path /weather/* {
        reverse_proxy localhost:8004
    }

    handle_path /trackiq/* {
        reverse_proxy localhost:8005
    }

    handle_path /framer/* {
        reverse_proxy localhost:8007
    }

    handle_path /pacvue/* {
        reverse_proxy localhost:8008
    }

    handle_path /alpaca/* {
        reverse_proxy localhost:8009
    }

    handle_path /ta/* {
        reverse_proxy localhost:8011
    }

    handle_path /uw/* {
        reverse_proxy localhost:8012
    }

    handle_path /datarova/* {
        reverse_proxy localhost:8013
    }

    handle_path /keepa/* {
        reverse_proxy localhost:8014
    }

    handle_path /scrapingbee/* {
        reverse_proxy localhost:8015
    }

    handle_path /oxylabs/* {
        reverse_proxy localhost:8016
    }

    handle {
        respond "Not Found" 404
    }
}
