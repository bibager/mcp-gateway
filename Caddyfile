:8080 {
    handle /health {
        respond "OK" 200
    }

    # OAuth endpoints at root — forward to GA server for Claude's OAuth discovery
    handle /.well-known/oauth-protected-resource {
        reverse_proxy localhost:8002
    }
    handle /.well-known/oauth-authorization-server {
        reverse_proxy localhost:8002
    }
    handle /register {
        reverse_proxy localhost:8002
    }
    handle /authorize {
        reverse_proxy localhost:8002
    }
    handle /callback {
        reverse_proxy localhost:8002
    }
    handle /token {
        reverse_proxy localhost:8002
    }

    handle_path /monarch/* {
        reverse_proxy localhost:8000
    }

    handle_path /todoist/* {
        reverse_proxy localhost:8001
    }

    handle_path /ga/* {
        reverse_proxy localhost:8002
    }

    handle_path /gitlab/* {
        reverse_proxy localhost:8003
    }

    handle {
        respond "Not Found" 404
    }
}
