:8080 {
    # Health check for the gateway itself
    handle /health {
        respond "OK" 200
    }

    # --- Todoist MCP: todoist.bibager.com (MUST be before GA OAuth routes) ---
    @todoist header Host todoist.bibager.com
    handle @todoist {
        reverse_proxy localhost:8001
    }

    # --- Monarch MCP: monarch.bibager.com ---
    @monarch header Host monarch.bibager.com
    handle @monarch {
        reverse_proxy localhost:8000
    }

    # --- GitLab MCP: gitlab.bibager.com (future) ---
    @gitlab header Host gitlab.bibager.com
    handle @gitlab {
        reverse_proxy localhost:8003
    }

    # --- Weather MCP: weather.bibager.com ---
    @weather header Host weather.bibager.com
    handle @weather {
        reverse_proxy localhost:8004
    }

    # --- TrackIQ MCP: trackiq.bibager.com ---
    @trackiq header Host trackiq.bibager.com
    handle @trackiq {
        reverse_proxy localhost:8005
    }

    # --- GA MCP: mcp.bibager.com/ga/* and root OAuth ---
    @ga_path path /ga/*
    handle @ga_path {
        uri strip_prefix /ga
        reverse_proxy localhost:8002
    }

    # GA OAuth endpoints at root (for Claude OAuth discovery on mcp.bibager.com only)
    @ga_oauth path /.well-known/oauth-protected-resource /.well-known/oauth-authorization-server /register /authorize /callback /token
    handle @ga_oauth {
        reverse_proxy localhost:8002
    }

    # Fallback path-based routes (for direct access)
    handle_path /monarch/* {
        reverse_proxy localhost:8000
    }

    handle_path /todoist/* {
        reverse_proxy localhost:8001
    }

    handle_path /gitlab/* {
        reverse_proxy localhost:8003
    }

    handle_path /weather/* {
        reverse_proxy localhost:8004
    }

    handle_path /trackiq/* {
        reverse_proxy localhost:8005
    }

    handle {
        respond "Not Found" 404
    }
}
